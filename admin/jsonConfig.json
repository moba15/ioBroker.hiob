{
  "i18n": true,
  "type": "panel",
  "items": {
    "_headerAdapter": {
      "type": "header",
      "text": "hiob-dev adapter settings",
      "size": 2
    },
    "port": {
      "type": "port",
      "label": "select a port",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4,
      "default": 8090,
      "newLine": true
    },
    "useCert": {
      "type": "checkbox",
      "label": "useCert",
      "tooltip": "useCert_tooltip",
      "default": false,
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4
    },
    "staticLink": {
      "type": "staticLink",
      "text": "link to description",
      "href": "https://github.com/moba15/ioBroker.hiob/blob/main/docs%2Fde%2FsecureCon.md",
      "icon": "info",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4
    },
    "certPath": {
      "newLine": true,
      "type": "text",
      "label": "certPath",
      "tooltip": "certPath_tooltip",
      "disabled": "!data.useCert",
      "hidden": "!data.useCert",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4,
      "default": ""
    },
    "keyPath": {
      "newLine": true,
      "type": "text",
      "label": "keyPath",
      "tooltip": "keyPath_tooltip",
      "disabled": "!data.useCert",
      "hidden": "!data.useCert",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4,
      "default": ""
    },
    "notificationPassword": {
      "type": "password",
      "label": "notificationPassword",
      "tooltip": "notificationPassword_tooltip",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4,
      "default": ""
    },
    "generateNewUser": {
      "type": "sendTo",
      "command": "generateUuidAndSend",
      "label": "Generate Login Information",
      "variant": "contained",
      "color": "primary",
      "useNative": true,
      "newLine": true,
      "data": { "password": "${data.notificationPassword}" },
      "disabled": "data.userUUID",
      "xs": 6,
      "sm": 6,
      "md": 4,
      "lg": 3,
      "xl": 3
    },
    "resetUser": {
      "type": "sendTo",
      "command": "resetUser",
      "label": "Reset Login Information",
      "variant": "contained",
      "color": "primary",
      "useNative": true,
      "newLine": false,
      "disabled": "!data.userUUID",
       "xs": 6,
      "sm": 6,
      "md": 4,
      "lg": 3,
      "xl": 3
    },
    "userUUID": {
      "type": "text",
      "label": "userUUID",
      "tooltip": "userUUID",
      "readOnly": true,
      "copyToClipboard": true,
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4,
      "default": ""
    },
    "qrCode2": {
      "type": "qrCodeSendTo",
      "command": "getUserUuidQr",
      "alsoDependsOn": ["userUUID"],
      "label": "userUUID",
      "tooltip": "userUUID",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4,
      "hidden": "!data.userUUID"
    }
  }
}
