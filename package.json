{
  "name": "iobroker.hiob-dev",
  "version": "0.3.0-alpha.0",
  "description": "Visualization for mobile phones",
  "author": {
    "name": "mor15Euro",
    "email": "moritz@bachmaiers.de"
  },
  "homepage": "https://github.com/moba15/ioBroker.hiob.git",
  "license": "MIT",
  "keywords": [
    "Android",
    "Visualization",
    "APP",
    "Widgets",
    "Templates",
    "home automation",
    "ioBroker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/moba15/ioBroker.hiob.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@iobroker/adapter-core": "^3.3.2",
    "async-mutex": "^0.5.0",
    "bcrypt": "^5.1.1",
    "crypto-js": "^4.2.0",
    "google-protobuf": "^3.21.4",
    "protobufjs": "^7.5.4",
    "supabase": "^2.92.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node18": "^18.2.6",
    "@types/bcrypt": "^5.0.2",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^7.1.8",
    "@types/crypto-js": "^4.2.2",
    "@types/google-protobuf": "^3.15.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^17.0.4",
    "@types/sinon-chai": "^3.2.12",
    "@types/ws": "^8.18.1",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "eslint": "^9.39.4",
    "mocha": "^7.2.0",
    "protobufjs-cli": "^1.2.0",
    "protoc-gen-grpc": "^2.0.4",
    "proxyquire": "^2.1.3",
    "rimraf": "^5.0.10",
    "sinon": "^18.0.1",
    "sinon-chai": "^3.7.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.2"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "switch:dev": "ts-node scripts/toggle-identity.ts dev",
    "switch:release": "ts-node scripts/toggle-identity.ts release",
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "build:dev": "npm run switch:dev && npm run build",
    "build:release": "npm run switch:release && npm run build",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "test:ts": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test:loginmanager": "mocha --config test/mocharc.custom.json test/loginmanager.test.ts",
    "test:unit": "npm run test:loginmanager",
    "test": "npm run test:ts && npm run test:package && npm run test:unit",
    "check": "tsc --noEmit",
    "lint": "eslint -c eslint.config.mjs .",
    "lintFix": "eslint -c eslint.config.mjs . --fix",
    "translate": "translate-adapter",
    "release": "release-script",
    "generate": "rm -rf src/generated && mkdir -p src/generated &&  protoc  -I=hiob_protobuf --ts_out=grpc:'./src/generated' hiob_protobuf/packages.proto hiob_protobuf/state/state.proto  hiob_protobuf/login/login.proto hiob_protobuf/config_sync/config_sync.proto"
  },
  "bugs": {
    "url": "https://github.com/moba15/ioBroker.hiob/issues"
  },
  "readmeFilename": "README.md"
}
